# ========================================
# Kurumsal AI Asistan - Ortam Değişkenleri
# ========================================
# Bu dosyayı backend/.env olarak kopyalayın ve değerleri doldurun.

# Uygulama
APP_NAME="Kurumsal AI Asistan"
APP_VERSION="1.0.0"
DEBUG=true

# Güvenlik - ÖNEMLİ: Production'da mutlaka değiştirin!
SECRET_KEY="change-this-super-secret-key-in-production-min-32-chars"
ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Veritabanı
DATABASE_URL="sqlite+aiosqlite:///./ai_assistant.db"

# OpenAI API - ÖNEMLİ: Kendi API anahtarınızı girin
OPENAI_API_KEY="sk-your-openai-api-key-here"
OPENAI_MODEL="gpt-3.5-turbo"
OPENAI_EMBEDDING_MODEL="text-embedding-ada-002"

# Dosya Yükleme
UPLOAD_DIR="uploads"
MAX_FILE_SIZE=52428800
VECTOR_STORE_DIR="vector_stores"

# RAG Ayarları
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
TOP_K_RESULTS=5

# Cache (opsiyonel - Redis)
REDIS_URL=
CACHE_TTL=3600

# Loglama
LOG_LEVEL="INFO"
